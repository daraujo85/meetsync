{
  "name": "meetsync",
  "version": "0.4.3",
  "private": true,
  "description": "Captura as legendas do Google Meet, exibe em chat e exporta .txt/.json; correção, resumo e perguntas com IA via Ollama.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "zip": "node scripts/zip.mjs",
    "package": "npm run build && npm run zip",
    "publish:store": "node scripts/publish-store.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.19.21",
    "chrome-webstore-upload-cli": "^3.5.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  }
}
